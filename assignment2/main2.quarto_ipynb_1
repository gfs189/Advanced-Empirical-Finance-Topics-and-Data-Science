        "#| label: ex1-summary-and-missing\n",
        "\n",
        "# ── Part (b): Summary statistics and missing-value handling ───────────────────\n",
        "\n",
        "# Count missing values before imputation\n",
        "missing = (\n",
        "    data[CHAR_COLS + MACRO_COLS]\n",
        "    .isna()\n",
        "    .mean()\n",
        "    .mul(100)\n",
        "    .rename(\"Missing (%)\")\n",
        "    .reset_index()\n",
        "    .rename(columns={\"index\": \"Variable\"})\n",
        ")\n",
        "\n",
        "# Summary statistics table (mean, sd, p25, median, p75)\n",
        "summary = (\n",
        "    data[CHAR_COLS + MACRO_COLS]\n",
        "    .describe(percentiles=[0.25, 0.75])\n",
        "    .T[[\"mean\", \"std\", \"25%\", \"50%\", \"75%\"]]\n",
        "    .round(4)\n",
        ")\n",
        "print(summary)\n",
        "\n",
        "# --- Missing-value imputation ---\n",
        "# Stock characteristics: compute all cross-sectional medians in one grouped\n",
        "# operation, then fill NaNs vectorially — much faster than looping transforms.\n",
        "cs_medians = data.groupby(\"date\")[CHAR_COLS].transform(\"median\")\n",
        "data[CHAR_COLS] = data[CHAR_COLS].fillna(cs_medians)\n",
        "\n",
        "# Macro predictors: time-series variables – forward-fill within the panel\n",
        "# (each stock-month shares the same macro observation for that month).\n",
        "data[MACRO_COLS] = data[MACRO_COLS].ffill()\n",
        "\n",
        "# Drop remaining rows where ret_excess or mktcap_lag is still missing\n",
        "data = data.dropna(subset=[\"ret_excess\", \"mktcap_lag\"] + MACRO_COLS)\n",
        "\n",
        "# --- Distribution plot: standardised stock characteristics ---\n",
        "# Sample 50k rows for plotting speed (distribution shape is stable at this N)\n",
        "plot_data = (\n",
        "    data[CHAR_COLS]\n",
        "    .sample(n=min(50_000, len(data)), random_state=42)\n",
        "    .apply(lambda x: (x - x.mean()) / x.std())\n",
        "    .melt(var_name=\"Characteristic\", value_name=\"Standardised value\")\n",
        "    .assign(Characteristic=lambda d: d[\"Characteristic\"].str.replace(\"characteristic_\", \"\", regex=False))\n",
        ")\n",
        "plot_data[\"Standardised value\"] = plot_data[\"Standardised value\"].clip(-5, 5)\n",
        "\n",
        "char_dist_plot = (\n",
        "    ggplot(plot_data, aes(x=\"Standardised value\", fill=\"Characteristic\"))\n",
        "    + geom_density(alpha=0.35, color=\"white\", size=0.3)\n",
        "    + facet_wrap(\"~Characteristic\", scales=\"free_y\", ncol=5)\n",
        "    + theme_bw()\n",
        "    + theme(legend_position=\"none\", strip_text=element_text(size=7))\n",
        "    + labs(\n",
        "        title=\"Distribution of standardised stock characteristics (winsorised at ±5σ)\",\n",
        "        x=\"Standardised value\", y=\"Density\",\n",
        "    )\n",
        ")\n",
        "char_dist_plot.draw()\n",
        "\n",
        "# --- Return distribution by SIC division ---\n",
        "# Vectorised SIC2 → division mapping using pd.cut (no row-wise apply loop)\n",
        "sic2_int = pd.to_numeric(data[\"sic2\"], errors=\"coerce\")\n",
        "divisions = pd.cut(\n",
        "    sic2_int,\n",
        "    bins=[0, 9, 14, 17, 39, 49, 51, 59, 67, 89, np.inf],\n",
        "    labels=[\"Agriculture\",\"Mining\",\"Construction\",\"Manufacturing\",\n",
        "            \"Transportation\",\"Wholesale\",\"Retail\",\"Finance\",\"Services\",\"Other\"],\n",
        "    right=True,\n",
        ")\n",
        "data[\"sic_division\"] = divisions.astype(str).where(sic2_int.notna(), \"Other\")\n",
        "\n",
        "industry_returns = (\n",
        "    data.groupby(\"sic_division\")[\"ret_excess\"]\n",
        "    .agg(mean_ret=(\"mean\"), n_obs=\"count\")\n",
        "    .reset_index()\n",
        "    .sort_values(\"mean_ret\", ascending=False)\n",
        "    .assign(mean_ret_pct=lambda d: d[\"mean_ret\"] * 100)\n",
        ")\n",
        "\n",
        "industry_plot = (\n",
        "    ggplot(industry_returns, aes(x=\"reorder(sic_division, mean_ret_pct)\", y=\"mean_ret_pct\"))\n",
        "    + geom_col(fill=\"#2166ac\", alpha=0.8)\n",
        "    + coord_flip()\n",
        "    + theme_bw()\n",
        "    + labs(\n",
        "        title=\"Mean monthly excess return by SIC division (post-2000)\",\n",
        "        x=\"\", y=\"Mean excess return (%)\",\n",
        "    )\n",
        ")\n",
        "industry_plot.draw()"
      ],
      "id": "ex1-summary-and-missing",
      "execution_count": null,
      "outputs": []
