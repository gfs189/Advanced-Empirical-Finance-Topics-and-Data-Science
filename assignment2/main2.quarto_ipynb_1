        "#| label: ex1-feature-matrix\n",
        "\n",
        "# ── Part (c): Feature matrix with interactions and SIC dummies ────────────────\n",
        "\n",
        "# One-hot encode the 10 SIC divisions (drop_first avoids multicollinearity)\n",
        "sic_dummies = pd.get_dummies(data[\"sic_division\"], prefix=\"sic\", drop_first=True, dtype=float)\n",
        "\n",
        "# Build interaction terms: each stock characteristic × each macro variable\n",
        "# → 10 chars × 4 macro = 40 interaction columns\n",
        "interaction_cols = []\n",
        "for char in CHAR_COLS:\n",
        "    for macro in MACRO_COLS:\n",
        "        col_name = f\"{char}_x_{macro}\"\n",
        "        data[col_name] = data[char] * data[macro]\n",
        "        interaction_cols.append(col_name)\n",
        "\n",
        "# Assemble final feature matrix X and target vector y\n",
        "# Order: [stock characteristics | interactions | SIC dummies]\n",
        "feature_cols = CHAR_COLS + interaction_cols\n",
        "X = pd.concat([data[feature_cols].reset_index(drop=True),\n",
        "               sic_dummies.reset_index(drop=True)], axis=1)\n",
        "y = data[\"ret_excess\"].values\n",
        "\n",
        "# Retain metadata for later portfolio construction\n",
        "meta = data[[\"permno\", \"date\", \"mktcap_lag\"]].reset_index(drop=True)\n",
        "\n",
        "print(\n",
        "    f\"Feature matrix: {X.shape[0]:,} rows × {X.shape[1]} columns\\n\"\n",
        "    f\"  {len(CHAR_COLS)} stock characteristics\\n\"\n",
        "    f\"  {len(interaction_cols)} interaction terms (chars × macro)\\n\"\n",
        "    f\"  {sic_dummies.shape[1]} SIC division dummies\"\n",
        ")"
      ],
      "id": "ex1-feature-matrix",
      "execution_count": null,
      "outputs": []
    },
