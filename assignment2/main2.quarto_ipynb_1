        "#| label: ex2-tune-gbm\n",
        "\n",
        "# ── Part (c): Gradient Boosted Trees – hyperparameter tuning ─────────────────\n",
        "# Objective: minimise MSE by additively fitting shallow trees to residuals.\n",
        "# Tuning grid: max_depth (tree complexity), n_estimators (ensemble size),\n",
        "# min_samples_leaf (regularisation via minimum node size).\n",
        "\n",
        "gbm_grid = [\n",
        "    {\"n_estimators\": n, \"max_depth\": d, \"min_samples_leaf\": l}\n",
        "    for n in [100, 300]\n",
        "    for d in [2, 3, 5]\n",
        "    for l in [500, 1000]\n",
        "]\n",
        "\n",
        "gbm_results = []\n",
        "for params in gbm_grid:\n",
        "    model = GradientBoostingRegressor(\n",
        "        **params,\n",
        "        learning_rate=0.01,\n",
        "        subsample=0.5,       # stochastic GBM – faster and regularises\n",
        "        random_state=42,\n",
        "    )\n",
        "    model.fit(X_train, y_train)\n",
        "    val_mse = mean_squared_error(y_val, model.predict(X_val))\n",
        "    gbm_results.append({**params, \"val_mse\": val_mse})\n",
        "    print(f\"GBM {params}  →  val MSE: {val_mse:.6f}\")\n",
        "\n",
        "gbm_results_df = pd.DataFrame(gbm_results).sort_values(\"val_mse\")\n",
        "best_gbm_params = gbm_results_df.iloc[0].drop(\"val_mse\").to_dict()\n",
        "best_gbm_params = {k: int(v) for k, v in best_gbm_params.items()}\n",
        "print(f\"\\nBest GBM params: {best_gbm_params}\")\n",
        "\n",
        "# Refit best GBM on train + validation combined (maximises data for final model)\n",
        "best_gbm = GradientBoostingRegressor(\n",
        "    **best_gbm_params, learning_rate=0.01, subsample=0.5, random_state=42\n",
        ")\n",
        "best_gbm.fit(\n",
        "    np.vstack([X_train, X_val]),\n",
        "    np.concatenate([y_train, y_val]),\n",
        ")\n",
        "\n",
        "# Complexity plot: validation MSE vs number of trees (using staged_predict)\n",
        "staged_val_mse = [\n",
        "    mean_squared_error(y_val, pred)\n",
        "    for pred in best_gbm.staged_predict(X_val)\n",
        "]\n",
        "complexity_df = pd.DataFrame({\n",
        "    \"n_estimators\": range(1, len(staged_val_mse) + 1),\n",
        "    \"val_mse\": staged_val_mse,\n",
        "    \"set\": \"Validation\",\n",
        "})\n",
        "\n",
        "gbm_complexity_plot = (\n",
        "    ggplot(complexity_df, aes(x=\"n_estimators\", y=\"val_mse\"))\n",
        "    + geom_line(color=\"#d73027\")\n",
        "    + theme_bw()\n",
        "    + labs(\n",
        "        title=\"GBM: validation MSE vs number of trees\",\n",
        "        x=\"Number of trees\", y=\"MSE\",\n",
        "    )\n",
        ")\n",
        "gbm_complexity_plot.draw()"
      ],
      "id": "ex2-tune-gbm",
      "execution_count": null,
      "outputs": []
    },
