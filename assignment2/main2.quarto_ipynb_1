        "#| label: ex2-tune-nn\n",
        "\n",
        "# ── Part (c): Neural Network – hyperparameter tuning ─────────────────────────\n",
        "# Objective: minimise MSE via stochastic gradient descent (Adam).\n",
        "# Architecture: fully connected layers with ReLU activations.\n",
        "# Tuning: hidden layer size (width/depth), L2 penalty (alpha), learning rate.\n",
        "# Features are standardised first – mandatory for neural nets (lecture slide).\n",
        "\n",
        "scaler = StandardScaler()\n",
        "X_train_s = scaler.fit_transform(X_train)   # fit only on train → no leakage\n",
        "X_val_s   = scaler.transform(X_val)\n",
        "X_test_s  = scaler.transform(X_test)\n",
        "\n",
        "nn_grid = [\n",
        "    {\"hidden_layer_sizes\": h, \"alpha\": a, \"learning_rate_init\": lr}\n",
        "    for h  in [(32,), (64, 32), (32, 16, 8)]\n",
        "    for a  in [1e-4, 1e-3, 1e-2]\n",
        "    for lr in [1e-3, 5e-4]\n",
        "]\n",
        "\n",
        "nn_results = []\n",
        "for params in nn_grid:\n",
        "    model = MLPRegressor(\n",
        "        **params,\n",
        "        activation=\"relu\",\n",
        "        solver=\"adam\",\n",
        "        max_iter=100,\n",
        "        early_stopping=True,   # stops when val loss stops improving\n",
        "        validation_fraction=0.1,\n",
        "        random_state=42,\n",
        "    )\n",
        "    model.fit(X_train_s, y_train)\n",
        "    val_mse = mean_squared_error(y_val, model.predict(X_val_s))\n",
        "    nn_results.append({\n",
        "        \"hidden_layer_sizes\": str(params[\"hidden_layer_sizes\"]),\n",
        "        \"alpha\": params[\"alpha\"],\n",
        "        \"learning_rate_init\": params[\"learning_rate_init\"],\n",
        "        \"val_mse\": val_mse,\n",
        "    })\n",
        "    print(f\"NN {params}  →  val MSE: {val_mse:.6f}\")\n",
        "\n",
        "nn_results_df = pd.DataFrame(nn_results).sort_values(\"val_mse\")\n",
        "best_nn_row   = nn_results_df.iloc[0]\n",
        "print(f\"\\nBest NN params:\\n{best_nn_row}\")\n",
        "\n",
        "# Refit best NN on train + validation combined\n",
        "best_nn = MLPRegressor(\n",
        "    hidden_layer_sizes=eval(best_nn_row[\"hidden_layer_sizes\"]),\n",
        "    alpha=best_nn_row[\"alpha\"],\n",
        "    learning_rate_init=best_nn_row[\"learning_rate_init\"],\n",
        "    activation=\"relu\",\n",
        "    solver=\"adam\",\n",
        "    max_iter=200,\n",
        "    random_state=42,\n",
        ")\n",
        "best_nn.fit(\n",
        "    np.vstack([X_train_s, X_val_s]),\n",
        "    np.concatenate([y_train, y_val]),\n",
        ")"
