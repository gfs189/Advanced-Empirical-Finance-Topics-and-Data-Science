      "source": [
        "#| label: ex2-split\n",
        "\n",
        "from sklearn.ensemble import GradientBoostingRegressor\n",
        "from sklearn.neural_network import MLPRegressor\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.metrics import mean_squared_error\n",
        "import joblib\n",
        "\n",
        "# ── Part (b): Time-respecting train / validation / test split ────────────────\n",
        "# Split by unique dates to prevent any future information leaking into training.\n",
        "# The most recent 20% of months are held out as the test set (never touched\n",
        "# during model selection). The remaining 80% is split 75/25 into train and\n",
        "# validation, giving roughly 60% / 20% / 20% overall. This generous training\n",
        "# window captures multiple business cycles while the validation set is large\n",
        "# enough to give stable performance estimates for hyperparameter selection.\n",
        "\n",
        "unique_dates = np.sort(meta[\"date\"].unique())\n",
        "n_dates      = len(unique_dates)\n",
        "\n",
        "test_cutoff  = unique_dates[int(n_dates * 0.80)]  # last 20% → test\n",
        "val_cutoff   = unique_dates[int(n_dates * 0.60)]  # preceding 20% → validation\n",
        "\n",
        "date_col = meta[\"date\"].values\n",
        "\n",
        "train_mask = date_col <  val_cutoff\n",
        "val_mask   = (date_col >= val_cutoff) & (date_col < test_cutoff)\n",
        "test_mask  = date_col >= test_cutoff\n",
        "\n",
        "X_train, y_train = X[train_mask], y[train_mask]\n",
        "X_val,   y_val   = X[val_mask],   y[val_mask]\n",
        "X_test,  y_test  = X[test_mask],  y[test_mask]\n",
        "\n",
        "print(\n",
        "    f\"Train : {meta.loc[train_mask, 'date'].min()} → {meta.loc[train_mask, 'date'].max()}  \"\n",
        "    f\"({train_mask.sum():>7,} obs)\\n\"\n",
        "    f\"Val   : {meta.loc[val_mask,   'date'].min()} → {meta.loc[val_mask,   'date'].max()}  \"\n",
        "    f\"({val_mask.sum():>7,} obs)\\n\"\n",
        "    f\"Test  : {meta.loc[test_mask,  'date'].min()} → {meta.loc[test_mask,  'date'].max()}  \"\n",
        "    f\"({test_mask.sum():>7,} obs)\"\n",
        ")"
      ],
      "id": "ex2-split",
      "execution_count": null,
      "outputs": []
    },
