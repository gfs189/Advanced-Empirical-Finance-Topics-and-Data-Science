   "source": [
    "def compute_efficient_frontier(mu, Sigma, n_points=100):\n",
    "    \"\"\"Compute the mean-variance efficient frontier and tangency portfolio.\n",
    "    \n",
    "    Parameters: mu (expected returns), Sigma (covariance matrix), n_points (frontier resolution)\n",
    "    Returns: frontier (DataFrame with mu_p, sigma_p, weights), tangency (dict with portfolio stats)\n",
    "    \"\"\"\n",
    "    N = len(mu)\n",
    "    iota = np.ones(N)\n",
    "    Sigma_inv = np.linalg.inv(Sigma)\n",
    "\n",
    "    # Scalar constants from the analytical frontier solution\n",
    "    A = iota @ Sigma_inv @ mu\n",
    "    B = mu @ Sigma_inv @ mu\n",
    "    C = iota @ Sigma_inv @ iota\n",
    "    D = B * C - A ** 2  # Determinant-like term ensuring a unique frontier\n",
    "\n",
    "    def frontier_weights(mu_bar):\n",
    "        # Two-fund separation: any frontier portfolio is a combination of g and h\n",
    "        g = (B * (Sigma_inv @ iota) - A * (Sigma_inv @ mu)) / D\n",
    "        h = (C * (Sigma_inv @ mu) - A * (Sigma_inv @ iota)) / D\n",
    "        return g + h * mu_bar\n",
    "\n",
    "    # Evaluate frontier across a grid of target returns\n",
    "    mu_range = np.linspace(mu.min(), mu.max() * 1.5, n_points)\n",
    "\n",
    "    records = []\n",
    "    for mu_bar in mu_range:\n",
    "        w = frontier_weights(mu_bar)\n",
    "        mu_p = w @ mu\n",
    "        sigma_p = np.sqrt(w @ Sigma @ w)\n",
    "        records.append({\"mu_p\": mu_p, \"sigma_p\": sigma_p, \"weights\": w})\n",
    "\n",
    "    frontier = pd.DataFrame(records)\n",
    "\n",
    "    # Tangency portfolio: maximizes Sharpe ratio, computed analytically\n",
    "    w_tan = (Sigma_inv @ mu) / (iota @ Sigma_inv @ mu)\n",
    "    mu_tan = w_tan @ mu\n",
    "    sigma_tan = np.sqrt(w_tan @ Sigma @ w_tan)\n",
    "    sharpe_tan = mu_tan / sigma_tan\n",
    "\n",
    "    tangency = {\n",
    "        \"weights\": w_tan,\n",
    "        \"mu_p\": mu_tan,\n",
    "        \"sigma_p\": sigma_tan,\n",
    "        \"sharpe\": sharpe_tan\n",
    "    }\n",
    "\n",
    "    return frontier, tangency\n",
    "\n",
    "# Compute frontier and tangency portfolio using the true parameters\n",
    "frontier, tangency = compute_efficient_frontier(mu, Sigma)\n",
    "\n",
    "print(f\"Tangency portfolio Sharpe: {tangency['sharpe']:.4f}\")\n",
    "print(f\"Tangency mu (monthly):     {tangency['mu_p']:.4f}\")\n",
    "print(f\"Tangency sigma (monthly):  {tangency['sigma_p']:.4f}\")"
   ]
