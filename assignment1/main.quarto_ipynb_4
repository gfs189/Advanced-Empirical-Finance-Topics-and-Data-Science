   "source": [
    "#| label: monthly returns\n",
    "\n",
    "# Aggregate daily S&P 500 returns to monthly by compounding daily returns\n",
    "# within each month: (1+r1)(1+r2)...(1+rT) - 1\n",
    "returns_monthly_sp500 = (returns_sp500\n",
    "    .assign(date=returns_sp500[\"date\"].dt.to_period(\"M\").dt.to_timestamp())\n",
    "    .groupby([\"symbol\", \"date\"], as_index=False)\n",
    "    .agg(ret=(\"ret\", lambda x: np.prod(1 + x) - 1))\n",
    ")\n",
    "\n",
    "# Aggregate T-Bill rate to monthly by taking the last observed rate of each month\n",
    "returns_monthly_tbill = (\n",
    "    returns_tbill\n",
    "    .assign(date=lambda x: x[\"date\"].dt.to_period(\"M\").dt.to_timestamp())\n",
    "    .groupby([\"symbol\", \"date\"], as_index=False)\n",
    "    .agg(ret=(\"ret\", \"last\"))   \n",
    ")\n",
    "\n",
    "# Convert annualized T-Bill yield (in %) to a monthly rate\n",
    "# using the formula: rf = (1 + IRX/100)^(1/12) - 1\n",
    "returns_monthly_tbill[\"risk_free\"] = (\n",
    "    (1 + returns_monthly_tbill[\"ret\"] / 100) ** (1/12) - 1\n",
    ")\n",
    "\n",
    "# Drop the raw annualized rate column, keeping only the monthly risk-free rate\n",
    "returns_monthly_tbill = returns_monthly_tbill.drop(columns=\"ret\")\n",
    "\n",
    "# Merge S&P 500 and T-Bill data on date and compute monthly excess returns\n",
    "monthly_ret = (returns_monthly_tbill\n",
    "    .merge(returns_monthly_sp500, how=\"inner\", on=\"date\")\n",
    "    .assign(ret_excess=lambda x: x[\"ret\"] - x[\"risk_free\"])\n",
    ")"
