    "#| label: out of sample sharpe ratios across strategies\n",
    "\n",
    "def compute_portfolio_weights(mu_hat, Sigma_hat, sim, N):\n",
    "    iota = np.ones(N)\n",
    "    Sigma_hat_inv = np.linalg.inv(Sigma_hat)\n",
    "\n",
    "    # Plug-in tangency: maximizes Sharpe using sample estimates (unconstrained)\n",
    "    w_tan = Sigma_hat_inv @ mu_hat / (iota @ Sigma_hat_inv @ mu_hat)\n",
    "\n",
    "    # Naive diversification: equal weight across all N assets\n",
    "    w_ew = iota / N\n",
    "\n",
    "    # Minimum variance: minimizes portfolio variance, avoids estimating expected returns\n",
    "    w_mv = Sigma_hat_inv @ iota / (iota @ Sigma_hat_inv @ iota)\n",
    "\n",
    "    # Short-sell constrained tangency: maximizes Sharpe with non-negativity constraints\n",
    "    # Reduces extreme positions driven by estimation error via quadratic programming\n",
    "    def neg_sharpe(w):\n",
    "        mu_p = w @ mu_hat\n",
    "        sigma_p = np.sqrt(w @ Sigma_hat @ w)\n",
    "        return -mu_p / sigma_p\n",
    "\n",
    "    constraints = {\"type\": \"eq\", \"fun\": lambda w: np.sum(w) - 1}\n",
    "    bounds = [(0, None)] * N  # No short-selling: all weights >= 0\n",
    "    result = minimize(neg_sharpe, iota / N, method=\"SLSQP\", bounds=bounds, constraints=constraints)\n",
    "    w_constrained = result.x\n",
    "\n",
    "    return {\n",
    "        \"Plug-in tangency\": w_tan,\n",
    "        \"Equal weight\": w_ew,\n",
    "        \"Minimum variance\": w_mv,\n",
    "        \"Constrained tangency\": w_constrained,\n",
    "    }\n",
    "\n",
    "def evaluate_strategies(T, mu, Sigma, N):\n",
    "    # Draw a synthetic sample of length T from the true DGP\n",
    "    sim = simulate_returns(T, mu, Sigma)\n",
    "    \n",
    "    # Estimate mean vector and covariance matrix from the sample\n",
    "    mu_hat = sim.mean(axis=0)\n",
    "    Sigma_hat = np.cov(sim, rowvar=False)\n",
    "\n",
    "    # Compute weights for all strategies using estimated parameters\n",
    "    weights = compute_portfolio_weights(mu_hat, Sigma_hat, sim, N)\n",
    "\n",
    "    # Evaluate each strategy using TRUE parameters (out-of-sample performance)\n",
    "    records = []\n",
    "    for name, w in weights.items():\n",
    "        mu_p = w @ mu\n",
    "        sigma_p = np.sqrt(w @ Sigma @ w)\n",
    "        sharpe = mu_p / sigma_p\n",
    "        records.append({\"strategy\": name, \"mu_p\": mu_p, \"sigma_p\": sigma_p, \"sharpe\": sharpe})\n",
    "\n",
    "    return records\n",
    "\n",
    "# Sample sizes to study: 5, 10, 20, and 100 years of monthly data\n",
    "T_values = [60, 120, 240, 1200]\n",
    "n_simulations = 500\n",
    "\n",
    "records = []\n",
    "for T in T_values:\n",
    "    for _ in range(n_simulations):\n",
    "        results = evaluate_strategies(T, mu, Sigma, N)\n",
    "        for r in results:\n",
    "            r[\"T\"] = f\"T = {T}\"\n",
    "            records.append(r)\n",
    "\n",
    "strategy_results = pd.DataFrame(records)\n",
