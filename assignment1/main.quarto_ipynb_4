   "source": [
    "# Set random seed for reproducibility\n",
    "np.random.seed(2026)\n",
    "\n",
    "# Number of synthetic assets\n",
    "N = 50\n",
    "\n",
    "# Draw factor loadings and idiosyncratic volatilities from uniform distributions\n",
    "# beta_i ~ Uniform(0.5, 1.5) controls each asset's exposure to the market factor\n",
    "# sigma_eps_i ~ Uniform(0.10/sqrt(12), 0.30/sqrt(12)) is the monthly idiosyncratic volatility\n",
    "beta = np.random.uniform(0.5, 1.5, N)\n",
    "sigma_eps = np.random.uniform(0.10 / np.sqrt(12), 0.30 / np.sqrt(12), N)\n",
    "\n",
    "# Compute true expected excess returns and covariance matrix from the single-factor model\n",
    "# mu_i = beta_i * mu_m\n",
    "# Sigma = sigma2_m * beta*beta' + diag(sigma_eps^2)\n",
    "mu = beta * mu_m\n",
    "Sigma = sigma2_m * np.outer(beta, beta) + np.diag(sigma_eps**2)"
   ]
