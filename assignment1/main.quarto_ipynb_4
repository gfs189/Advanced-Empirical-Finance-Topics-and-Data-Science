   "source": [
    "#| label: estimated frontier figure vs true frontier\n",
    "\n",
    "# Simulate T observations from the true multivariate normal distribution\n",
    "def simulate_returns(periods, expected_returns, covariance_matrix):\n",
    "    return np.random.multivariate_normal(expected_returns, covariance_matrix, size=periods)\n",
    "\n",
    "def compute_plug_in_frontier(T, mu, Sigma, n_points=100):\n",
    "    # Draw a synthetic sample of length T from the true DGP\n",
    "    sim = simulate_returns(T, mu, Sigma)\n",
    "    \n",
    "    # Estimate mean vector and covariance matrix from the sample\n",
    "    mu_hat = sim.mean(axis=0)\n",
    "    Sigma_hat = np.cov(sim, rowvar=False)\n",
    "    \n",
    "    # Compute the plug-in frontier using estimated parameters\n",
    "    frontier_hat, _ = compute_efficient_frontier(mu_hat, Sigma_hat, n_points)\n",
    "\n",
    "    # Re-evaluate plug-in weights using TRUE parameters to measure out-of-sample performance\n",
    "    records = []\n",
    "    for w in frontier_hat[\"weights\"]:\n",
    "        mu_p_true = w @ mu\n",
    "        sigma_p_true = np.sqrt(w @ Sigma @ w)\n",
    "        records.append({\"mu_p\": mu_p_true, \"sigma_p\": sigma_p_true})\n",
    "\n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "# Sample sizes to study: 5, 10, 20, and 100 years of monthly data\n",
    "T_values = [60, 120, 240, 1200]\n",
    "n_simulations = 25  # Number of frontier draws per T for visualization\n",
    "\n",
    "records = []\n",
    "for T in T_values:\n",
    "    for _ in range(n_simulations):\n",
    "        frontier_hat = compute_plug_in_frontier(T, mu, Sigma)\n",
    "        frontier_hat[\"T\"] = f\"T = {T}\"\n",
    "        records.append(frontier_hat)\n",
    "\n",
    "simulated_frontiers = pd.concat(records, ignore_index=True)\n",
    "\n",
    "# Plot plug-in frontiers (evaluated at true parameters) against the true frontier\n",
    "# Dispersion across light blue lines reflects estimation error for each T\n",
    "plot_5 = (\n",
    "    ggplot()\n",
    "    + geom_line(\n",
    "        data=simulated_frontiers,\n",
    "        mapping=aes(x=\"sigma_p\", y=\"mu_p\", group=\"T\"),\n",
    "        color=\"lightblue\", alpha=0.4, size=0.5\n",
    "    )\n",
    "    + geom_line(\n",
    "        data=frontier,\n",
    "        mapping=aes(x=\"sigma_p\", y=\"mu_p\"),\n",
    "        color=\"blue\", size=1\n",
