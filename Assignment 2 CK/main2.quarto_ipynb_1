      "source": [
        "#| label: ex4-variable-importance\n",
        "\n",
        "# ── Part (a): Variable importance via GKX ablation method ────────────────────\n",
        "# For each predictor, set ALL columns that involve it (the characteristic itself\n",
        "# plus its interaction columns) to the training-set mean. Regenerate predictions,\n",
        "# rebuild the long-short portfolio, and record the drop in annualised Sharpe ratio\n",
        "# relative to the test-set baseline. A larger Sharpe drop indicates a more\n",
        "# important predictor.\n",
        "\n",
        "def annualised_sharpe(ls_ret):\n",
        "    return ls_ret.mean() / ls_ret.std() * np.sqrt(12)\n",
        "\n",
        "baseline_sharpe_rf = annualised_sharpe(rf_ls_test)\n",
        "baseline_sharpe_nn = annualised_sharpe(nn_ls_test)\n",
        "\n",
        "# Training means for each column (used to zero out predictors before scaling)\n",
        "train_means = X_train_df.mean()\n",
        "\n",
        "# Group columns by original predictor: each characteristic or macro variable\n",
        "# groups together with all of its interaction columns.\n",
        "predictor_groups = {}\n",
        "for col in CHAR_COLS:\n",
        "    short = col.replace(\"characteristic_\", \"\")\n",
        "    predictor_groups[short] = [c for c in X.columns if col in c]\n",
        "\n",
        "for col in MACRO_COLS:\n",
        "    short = col.replace(\"macro_\", \"\")\n",
        "    predictor_groups[short] = [c for c in X.columns if col in c]\n",
        "\n",
        "for col in X.columns:\n",
        "    if col.startswith(\"sic_\"):\n",
        "        predictor_groups[col] = [col]\n",
        "\n",
        "importance_records = []\n",
        "for predictor, cols in predictor_groups.items():\n",
        "    for model_name, pipeline, baseline in [\n",
        "        (\"RF\", best_rf, baseline_sharpe_rf),\n",
        "        (\"NN\", best_nn, baseline_sharpe_nn),\n",
        "    ]:\n",
        "        # Zero out the predictor group by setting to training-set mean\n",
        "        X_ablated = X_test_df.copy()\n",
        "        X_ablated[cols] = train_means[cols].values\n",
        "\n",
        "        pred_ablated    = pipeline.predict(X_ablated)\n",
        "        ls_ablated, _   = build_long_short(pred_ablated, test_mask)\n",
        "        sharpe_drop     = baseline - annualised_sharpe(ls_ablated)\n",
        "\n",
        "        importance_records.append({\n",
        "            \"Model\":       model_name,\n",
        "            \"Predictor\":   predictor,\n",
        "            \"Sharpe drop\": sharpe_drop,\n",
        "            \"n_cols\":      len(cols),\n",
        "        })\n",
        "\n",
        "importance_df = pd.DataFrame(importance_records)\n",
        "\n",
        "# Top 3 most important predictors per model\n",
        "top3 = (\n",
        "    importance_df\n",
        "    .sort_values(\"Sharpe drop\", ascending=False)\n",
        "    .groupby(\"Model\")\n",
        "    .head(3)\n",
        "    .reset_index(drop=True)\n",
        "    [[\"Model\", \"Predictor\", \"Sharpe drop\"]]\n",
        "    .assign(**{\"Sharpe drop\": lambda d: d[\"Sharpe drop\"].round(3)})\n",
        ")\n",
        "\n",
        "display(Markdown(\"**Table 4.** Top 3 most important predictors per model (annualised Sharpe ratio drop).\"))\n",
        "display(Markdown(top3.to_markdown(index=False)))"
      ],
