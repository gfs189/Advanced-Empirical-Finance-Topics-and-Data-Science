        "#| label: ex3-turnover\n",
        "\n",
        "# ── Part (e): Portfolio turnover ──────────────────────────────────────────────\n",
        "# Monthly turnover = average fraction of the long (or short) leg replaced each\n",
        "# month. Computed as the sum of absolute value-weight changes divided by 2\n",
        "# (the divisor avoids double-counting simultaneous buys and sells).\n",
        "\n",
        "def compute_turnover(predictions, mask):\n",
        "    df_to = meta[mask].copy().reset_index(drop=True)\n",
        "    df_to[\"pred\"] = predictions\n",
        "\n",
        "    df_to[\"decile\"] = (\n",
        "        df_to.groupby(\"date\", group_keys=False)\n",
        "        .apply(lambda g: assign_portfolio(\n",
        "            data=g,\n",
        "            sorting_variable=\"pred\",\n",
        "            breakpoint_options=breakpoint_options(n_portfolios=N_PORTFOLIOS),\n",
        "            breakpoint_function=compute_breakpoints,\n",
        "        ))\n",
        "    )\n",
        "\n",
        "    # Retain only the top and bottom decile legs; compute value weights\n",
        "    legs = df_to[df_to[\"decile\"].isin([1, 10])].copy()\n",
        "    legs[\"weight\"] = legs.groupby([\"date\", \"decile\"])[\"mktcap_lag\"].transform(\n",
        "        lambda w: w / w.sum()\n",
        "    )\n",
        "    legs[\"side\"] = legs[\"decile\"].map({10: \"long\", 1: \"short\"})\n",
        "\n",
        "    turnovers = []\n",
        "    for side in [\"long\", \"short\"]:\n",
        "        sub = legs[legs[\"side\"] == side].pivot(\n",
        "            index=\"date\", columns=\"permno\", values=\"weight\"\n",
        "        ).fillna(0)\n",
        "        # Absolute month-over-month weight change, summed across stocks\n",
        "        to = sub.diff().abs().sum(axis=1) / 2\n",
        "        turnovers.append(to)\n",
        "\n",
        "    avg_turnover = pd.concat(turnovers, axis=1).mean(axis=1)\n",
        "    return avg_turnover.mean()\n",
        "\n",
        "rf_to_val  = compute_turnover(rf_pred_val,  val_mask)\n",
        "rf_to_test = compute_turnover(rf_pred_test, test_mask)\n",
        "nn_to_val  = compute_turnover(nn_pred_val,  val_mask)\n",
        "nn_to_test = compute_turnover(nn_pred_test, test_mask)\n",
        "\n",
        "turnover_df = pd.DataFrame({\n",
        "    \"Model\":             [\"RF\", \"RF\", \"NN\", \"NN\"],\n",
        "    \"Period\":            [\"Validation\", \"Test\", \"Validation\", \"Test\"],\n",
        "    \"Monthly turnover\":  [f\"{rf_to_val:.1%}\", f\"{rf_to_test:.1%}\",\n",
        "                          f\"{nn_to_val:.1%}\", f\"{nn_to_test:.1%}\"],\n",
        "})\n",
        "\n",
        "display(Markdown(\"**Table 3.** Average monthly portfolio turnover by model and period.\"))\n",
        "display(Markdown(turnover_df.to_markdown(index=False)))"
