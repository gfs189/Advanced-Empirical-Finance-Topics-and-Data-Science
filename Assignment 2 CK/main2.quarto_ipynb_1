        "#| label: ex3-portfolios\n",
        "\n",
        "# ── Parts (b) & (c): Decile portfolios and long-short strategy ────────────────\n",
        "\n",
        "def build_long_short(predictions, mask):\n",
        "    \"\"\"\n",
        "    Sort stocks into decile portfolios by predicted return each month using\n",
        "    tf.assign_portfolio (course standard). Compute value-weighted returns per\n",
        "    decile using lagged market cap. Returns the monthly long-short series\n",
        "    (top decile minus bottom decile) and the full decile returns.\n",
        "    \"\"\"\n",
        "    df_ls = meta[mask].copy().reset_index(drop=True)\n",
        "    df_ls[\"pred\"]       = predictions\n",
        "    df_ls[\"ret_excess\"] = y[mask]\n",
        "\n",
        "    # Assign decile (1 = lowest predicted return, 10 = highest) within each month\n",
        "    df_ls[\"decile\"] = (\n",
        "        df_ls.groupby(\"date\", group_keys=False)\n",
        "        .apply(lambda g: assign_portfolio(\n",
        "            data=g,\n",
        "            sorting_variable=\"pred\",\n",
        "            breakpoint_options=breakpoint_options(n_portfolios=N_PORTFOLIOS),\n",
        "            breakpoint_function=compute_breakpoints,\n",
        "        ))\n",
        "    )\n",
        "\n",
        "    # Value-weighted return per decile-month using lagged market capitalisation\n",
        "    vw = (\n",
        "        df_ls.groupby([\"date\", \"decile\"])\n",
        "        .apply(\n",
        "            lambda g: (g[\"ret_excess\"] * g[\"mktcap_lag\"]).sum() / g[\"mktcap_lag\"].sum(),\n",
        "            include_groups=False,\n",
        "        )\n",
        "        .reset_index(name=\"vw_ret\")\n",
        "    )\n",
        "\n",
        "    # Long-short: long the top decile (10), short the bottom decile (1)\n",
        "    top = vw[vw[\"decile\"] == 10].set_index(\"date\")[\"vw_ret\"]\n",
        "    bot = vw[vw[\"decile\"] == 1].set_index(\"date\")[\"vw_ret\"]\n",
        "    ls  = (top - bot).rename(\"ls_ret\").dropna()\n",
        "    return ls, vw\n",
        "\n",
        "rf_ls_val,  rf_deciles_val  = build_long_short(rf_pred_val,  val_mask)\n",
        "rf_ls_test, rf_deciles_test = build_long_short(rf_pred_test, test_mask)\n",
        "nn_ls_val,  nn_deciles_val  = build_long_short(nn_pred_val,  val_mask)\n",
        "nn_ls_test, nn_deciles_test = build_long_short(nn_pred_test, test_mask)"
