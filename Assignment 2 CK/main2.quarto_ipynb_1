      "source": [
        "#| label: ex1-missing-imputation\n",
        "#| fig-cap: Distribution of standardised stock characteristics (winsorised at 2.5% each tail). Each panel shows the cross-sectional density of one characteristic after standardisation.\n",
        "\n",
        "# --- Missing-value imputation ---\n",
        "# Stock characteristics: cross-sectional median imputation within each month.\n",
        "# This preserves the relative ranking of stocks while filling gaps caused by\n",
        "# incomplete reporting, and is consistent with the GKX methodology.\n",
        "cs_medians = data.groupby(\"date\")[CHAR_COLS].transform(\"median\")\n",
        "data[CHAR_COLS] = data[CHAR_COLS].fillna(cs_medians)\n",
        "\n",
        "# Macro predictors: forward-fill within the time series. Macro variables are\n",
        "# observed at the market level and do not vary cross-sectionally, so a missing\n",
        "# value in a given month is best replaced by the most recent available value.\n",
        "data[MACRO_COLS] = data[MACRO_COLS].ffill()\n",
        "\n",
        "# Drop any remaining rows where the target (ret_excess) or weights (mktcap_lag)\n",
        "# or macro predictors are still missing after imputation.\n",
        "data = data.dropna(subset=[\"ret_excess\", \"mktcap_lag\"] + MACRO_COLS)\n",
        "\n",
        "# --- Distribution plot: standardised stock characteristics ---\n",
        "# Sample N_PLOT_SAMPLE rows for plotting speed; distribution shape is stable at this N.\n",
        "plot_data = (\n",
        "    data[CHAR_COLS]\n",
        "    .sample(n=min(N_PLOT_SAMPLE, len(data)), random_state=RANDOM_STATE)\n",
        "    .apply(lambda x: (x - x.mean()) / x.std())\n",
        "    .melt(var_name=\"Characteristic\", value_name=\"Standardised value\")\n",
        "    .assign(Characteristic=lambda d: d[\"Characteristic\"].str.replace(\"characteristic_\", \"\", regex=False))\n",
        ")\n",
        "# Winsorise at WINSORIZE_CUT each tail using the course-standard tidyfinance function\n",
        "plot_data[\"Standardised value\"] = tf.winsorize(\n",
        "    plot_data[\"Standardised value\"].values, cut=WINSORIZE_CUT\n",
        ")\n",
        "\n",
        "char_dist_plot = (\n",
        "    ggplot(plot_data, aes(x=\"Standardised value\", fill=\"Characteristic\"))\n",
        "    + geom_density(alpha=0.35, color=\"white\", size=0.3)\n",
        "    + facet_wrap(\"~Characteristic\", scales=\"free_y\", ncol=5)\n",
        "    + theme_bw()\n",
        "    + theme(legend_position=\"none\", strip_text=element_text(size=7))\n",
        "    + labs(\n",
        "        title=\"Distribution of standardised stock characteristics (winsorised at 2.5% tails)\",\n",
        "        x=\"Standardised value\", y=\"Density\",\n",
        "    )\n",
        ")\n",
        "char_dist_plot.draw()"
      ],
