        "#| label: ex3-performance\n",
        "\n",
        "# ── Part (d): Performance metrics ─────────────────────────────────────────────\n",
        "# Load Fama-French 3-factor data from the course repository parquet file.\n",
        "# This file is part of the course materials available to all students.\n",
        "ff3 = pd.read_parquet(_dir / \"../../../course-repository/data-python/factors_ff3_monthly.parquet\")\n",
        "mkt = ff3.set_index(\"date\")[\"mkt_excess\"]\n",
        "mkt.index = pd.to_datetime(mkt.index)\n",
        "\n",
        "def performance_table(ls_ret, mkt_series, label):\n",
        "    \"\"\"\n",
        "    Compute annualised mean excess return, Sharpe ratio, and CAPM alpha\n",
        "    with its t-statistic for a given long-short return series.\n",
        "    \"\"\"\n",
        "    ls_ts = pd.to_datetime(ls_ret.index).to_period(\"M\").to_timestamp(\"M\")\n",
        "    mkt_copy = mkt_series.copy()\n",
        "    mkt_copy.index = pd.to_datetime(mkt_copy.index).to_period(\"M\").to_timestamp(\"M\")\n",
        "    mkt_aligned = mkt_copy.reindex(ls_ts)\n",
        "    reg_df = pd.DataFrame({\"ls\": ls_ret.values, \"mkt\": mkt_aligned.values},\n",
        "                          index=ls_ts).dropna()\n",
        "\n",
        "    mean_ann  = ls_ret.mean() * MONTHS_PER_YEAR\n",
        "    sharpe    = ls_ret.mean() / ls_ret.std() * np.sqrt(MONTHS_PER_YEAR)\n",
        "    capm      = smf.ols(\"ls ~ mkt\", data=reg_df).fit()\n",
        "    alpha_ann = capm.params[\"Intercept\"] * MONTHS_PER_YEAR\n",
        "    t_stat    = capm.tvalues[\"Intercept\"]\n",
        "\n",
        "    return pd.DataFrame({\n",
        "        \"Period\":                       [label],\n",
        "        \"Mean excess return (ann.)\":    [f\"{mean_ann:.2%}\"],\n",
        "        \"Sharpe ratio (ann.)\":          [f\"{sharpe:.2f}\"],\n",
        "        \"CAPM alpha (ann.)\":            [f\"{alpha_ann:.2%}\"],\n",
        "        \"t-statistic\":                  [f\"{t_stat:.2f}\"],\n",
        "    })\n",
        "\n",
        "def mkt_benchmark(mkt_series, mask, label):\n",
        "    \"\"\"Annualised mean and Sharpe ratio of the market portfolio over a given period.\"\"\"\n",
        "    dates    = pd.to_datetime(np.sort(meta.loc[mask, \"date\"].unique())).to_period(\"M\").to_timestamp(\"M\")\n",
        "    mkt_copy = mkt_series.copy()\n",
        "    mkt_copy.index = pd.to_datetime(mkt_copy.index).to_period(\"M\").to_timestamp(\"M\")\n",
        "    mkt_sub  = mkt_copy[mkt_copy.index.isin(dates)]\n",
        "    mean_ann = mkt_sub.mean() * MONTHS_PER_YEAR\n",
        "    sharpe   = mkt_sub.mean() / mkt_sub.std() * np.sqrt(MONTHS_PER_YEAR)\n",
        "    return pd.DataFrame({\n",
        "        \"Period\":                    [label],\n",
        "        \"Mean excess return (ann.)\": [f\"{mean_ann:.2%}\"],\n",
        "        \"Sharpe ratio (ann.)\":       [f\"{sharpe:.2f}\"],\n",
        "    })\n",
        "\n",
        "perf = pd.concat([\n",
        "    performance_table(rf_ls_val,  mkt, \"RF – Validation\"),\n",
        "    performance_table(rf_ls_test, mkt, \"RF – Test\"),\n",
        "    performance_table(nn_ls_val,  mkt, \"NN – Validation\"),\n",
        "    performance_table(nn_ls_test, mkt, \"NN – Test\"),\n",
        "], ignore_index=True)\n",
        "\n",
        "bench = pd.concat([\n",
        "    mkt_benchmark(mkt, val_mask,  \"Market – Validation\"),\n",
        "    mkt_benchmark(mkt, test_mask, \"Market – Test\"),\n",
        "], ignore_index=True)\n",
        "\n",
        "display(Markdown(\"**Table 1.** Long-short portfolio performance by model and period.\"))\n",
        "display(Markdown(perf.to_markdown(index=False)))\n",
        "display(Markdown(\"**Table 2.** Market benchmark performance.\"))\n",
        "display(Markdown(bench.to_markdown(index=False)))"
